# Scalingo injecte PORT automatiquement — ne pas le définir en production
PORT=3000

# MongoDB — sur Scalingo, utiliser l'addon MongoDB et copier l'URL fournie
MONGO_URL=mongodb://localhost:27017/petitsemprunts

# URL publique de l'app (ex: https://petits-emprunts.osc-fr1.scalingo.io)
CLIENT_URL=http://localhost:5173

# Clé secrète JWT — générer une valeur aléatoire forte en production
JWT_SECRET=change_me_in_production

# Email SMTP (optionnel en dev — sans config, le lien s'affiche dans la console)
# Sur Scalingo : utiliser l'addon Mailgun ou un service SMTP externe
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Petits Emprunts Entre Amis" <no-reply@petitsemprunts.fr>

# NODE_ENV — mettre "production" sur Scalingo
NODE_ENV=development
